# ==========================================================
# GenomeAI Development Environment
# ==========================================================
# Copy this file to .env and modify values if needed.
#
# Default host ports intentionally avoid conflicts with
# locally installed PostgreSQL and Redis instances.
# ==========================================================

# ──────────────────────────────────────────────────────────
# PostgreSQL
# Container: 5432
# Host:      5433 (default)
# ──────────────────────────────────────────────────────────

GENOMEAI_POSTGRES_HOST=localhost
GENOMEAI_POSTGRES_PORT=5433
GENOMEAI_POSTGRES_USER=genomeai
GENOMEAI_POSTGRES_PASSWORD=genomeai
GENOMEAI_POSTGRES_DB=genomeai

# ──────────────────────────────────────────────────────────
# Redis
# Container: 6379
# Host:      6380 (default)
# ──────────────────────────────────────────────────────────

GENOMEAI_REDIS_HOST=localhost
GENOMEAI_REDIS_PORT=6380

# ──────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────

# UV_EXTRA_ARGS=--frozen
# VIRTUAL_ENV=.venv

# ──────────────────────────────────────────────────────────
# Node.js / Turborepo
# ──────────────────────────────────────────────────────────

# NODE_ENV=development
# TURBO_TOKEN=
# TURBO_TEAM=

# ──────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────

# GENOMEAI_LOG_LEVEL=debug
